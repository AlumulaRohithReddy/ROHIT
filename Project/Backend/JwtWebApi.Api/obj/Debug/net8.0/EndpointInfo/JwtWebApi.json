  "components": {
    "schemas": {
      "AdminResetPasswordDto": {
        "type": "object",
        "properties": {
          "NewPassword": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ApprovePolicyRequest": {
        "type": "object",
        "properties": {
          "UpdatedPremium": {
            "type": "number",
            "format": "double",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreateClaimRequestDto": {
        "required": [
          "ClaimedAmount",
          "Description",
          "IncidentDate",
          "IncidentLocation",
          "PolicyId"
        ],
        "type": "object",
        "properties": {
          "PolicyId": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "IncidentDate": {
            "type": "string",
            "format": "date-time"
          },
          "IncidentLocation": {
            "minLength": 1,
            "type": "string"
          },
          "Description": {
            "minLength": 1,
            "type": "string"
          },
          "ClaimedAmount": {
            "maximum": 100000000,
            "minimum": 0.01,
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "CreatePaymentRequest": {
        "type": "object",
        "properties": {
          "PolicyId": {
            "type": "integer",
            "format": "int32"
          },
          "PaymentMethod": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreatePolicyPlanRequestDto": {
        "required": [
          "BasePremium",
          "PlanName",
          "PolicyDurationMonths",
          "PolicyType"
        ],
        "type": "object",
        "properties": {
          "PlanName": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "PolicyType": {
            "minLength": 1,
            "type": "string"
          },
          "BasePremium": {
            "maximum": 100,
            "minimum": 0.01,
            "type": "number",
            "format": "double"
          },
          "MaxCoverageAmount": {
            "maximum": 100000000,
            "minimum": 0,
            "type": "number",
            "format": "double",
            "nullable": true
